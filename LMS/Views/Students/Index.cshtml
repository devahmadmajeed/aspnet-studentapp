<h2>Student CRUD (jQuery)</h2>

@Html.AntiForgeryToken()

<input type="hidden" id="studentId" />

<input id="name" placeholder="Name" class="form-control mb-2" />
<input id="email" placeholder="Email" class="form-control mb-2" />
<input id="age" placeholder="Age" class="form-control mb-2" />

<button onclick="saveStudent()" class="btn btn-success">Save</button>

<hr />

<table class="table" id="studentTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Age</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>