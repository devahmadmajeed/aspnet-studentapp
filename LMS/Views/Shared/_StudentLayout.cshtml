<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Student LMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    @Styles.Render("~/Content/css")
</head>
<body class="bg-light">
    <div class="d-flex min-vh-100">
        <aside class="bg-dark text-white p-3 flex-shrink-0" style="width: 260px;">
            <div class="mb-4">
                <span class="fw-bold fs-5">Student LMS</span>
                <div class="small text-secondary mt-1">@User.Identity.Name</div>
            </div>
            <nav class="nav flex-column gap-1">
                @Html.ActionLink("Dashboard", "Index", "StudentPortal", null, new { @class = "nav-link link-light rounded px-2 py-2" })
                @Html.ActionLink("My courses", "Courses", "StudentPortal", null, new { @class = "nav-link link-light rounded px-2 py-2" })
                @Html.ActionLink("Assignments", "Assignments", "StudentPortal", null, new { @class = "nav-link link-light rounded px-2 py-2" })
                @Html.ActionLink("Grades", "Grades", "StudentPortal", null, new { @class = "nav-link link-light rounded px-2 py-2" })
                @Html.ActionLink("Schedule", "Schedule", "StudentPortal", null, new { @class = "nav-link link-light rounded px-2 py-2" })
                @Html.ActionLink("Announcements", "Announcements", "StudentPortal", null, new { @class = "nav-link link-light rounded px-2 py-2" })
                @Html.ActionLink("Profile", "MyProfile", "StudentPortal", null, new { @class = "nav-link link-light rounded px-2 py-2" })
            </nav>
            <hr class="border-secondary" />
            @Html.ActionLink("Log out", "Logout", "Account", null, new { @class = "nav-link text-warning px-2 py-2" })
            <div class="small text-secondary mt-3">
                @Html.ActionLink("Public home", "Index", "Home", null, new { @class = "text-secondary" })
            </div>
        </aside>
        <main class="flex-grow-1 p-4">
            @RenderBody()
        </main>
    </div>
    @Scripts.Render("~/bundles/jquery")
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
