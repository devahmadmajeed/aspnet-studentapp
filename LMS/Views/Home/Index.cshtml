@{
    ViewBag.Title = "Home";
}

<main>
    <section class="row align-items-center mb-4" aria-labelledby="title">
        <div class="col-lg-8">
            <h1 id="title" class="display-6">Learning management system</h1>
            <p class="lead text-muted mb-3">Students sign in to open the portal with a sidebar menu. Administrators can add student accounts on the CRUD page.</p>
            <p class="mb-0">
                @Html.ActionLink("Student login", "Login", "Account", null, new { @class = "btn btn-primary me-2" })
                @Html.ActionLink("Add students (CRUD)", "Index", "Students", null, new { @class = "btn btn-outline-secondary" })
            </p>
        </div>
    </section>

    <div class="row g-3">
        <section class="col-md-4" aria-labelledby="gettingStartedTitle">
            <h2 id="gettingStartedTitle" class="h5">Getting started</h2>
            <p class="text-muted small">Create a student with email and password on the CRUD page, then use the same email and password on the login page.</p>
        </section>
        <section class="col-md-4" aria-labelledby="portalTitle">
            <h2 id="portalTitle" class="h5">Student portal</h2>
            <p class="text-muted small">After login you will see dashboard, courses, assignments, grades, schedule, announcements, and profile.</p>
        </section>
        <section class="col-md-4" aria-labelledby="authTitle">
            <h2 id="authTitle" class="h5">Authentication</h2>
            <p class="text-muted small">This sample uses forms authentication and a simple password check against the database (for learning only).</p>
        </section>
    </div>
</main>
